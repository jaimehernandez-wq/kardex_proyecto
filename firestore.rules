rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas permisivas pero con autenticación requerida
    match /{document=**} {
      allow read, write: if 
        // ✅ Requiere autenticación PERO es flexible
        request.auth != null ||
        // ✅ Permite acceso durante desarrollo (hasta fecha futura)
        request.time < timestamp.date(2026, 12, 31);
    }
  }
}